# Copy to .env for local Docker Compose:
#   cp .env.example .env

# ── Database ──
DB_HOST=localhost
DB_PORT=3307
DB_NAME=smart_contact_manager
DB_USERNAME=root
DB_PASSWORD=scm_secret
DB_SSL=false

# Full JDBC URL (overrides DB_HOST/DB_PORT/DB_NAME when set)
# DB_URL=jdbc:mysql://localhost:3307/smart_contact_manager?createDatabaseIfNotExist=true&allowPublicKeyRetrieval=true&useSSL=false

# ── Server ──
SERVER_PORT=8085
MYSQL_PORT=3307
SPRING_PROFILES_ACTIVE=default

# ── Uploads ──
UPLOAD_DIR=uploads

# ── Spring AI (optional — enables AI Assistant) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
